  "incident": {
    "id": "INC-2026-03-19-dns-misconfig-checkout",
    "env_key": "prod",
    "detected_at": "2026-03-19T13:42:00+00:00",
    "resolved_at": "2026-03-19T14:05:00+00:00",
    "title": "Checkout 5xx cascade from email.internal DNS resolution failure",
    "severity": "high",
    "summary": "Platform team rolled out ConfigMap cm-2026-03-19-1 which renamed the internal DNS search suffix from `svc.cluster.local` to `prod.svc.cluster.local`. The payments service's synchronous receipt step calls `email.internal`, which only resolved under the old suffix. Within 2 minutes of the rollout, payments started returning 502 for checkout requests; gateway propagated those as 5xx to clients. Reverting the ConfigMap at 13:58 restored resolution within 4 minutes; full recovery once payments' retry queue drained at 14:05.\n",
    "affected_services": [
      "gateway",
      "payments",
      "email"
    ]
  },
  "summary_lines": [
