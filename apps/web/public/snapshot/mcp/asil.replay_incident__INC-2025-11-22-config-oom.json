    "detected_at": "2025-11-22T16:30:00+00:00",
    "resolved_at": "2025-11-22T18:45:00+00:00",
    "title": "Feature-flag config push triggers OOM on recommendation service",
    "severity": "P2",
    "summary": "A feature-flag configuration push enabled a new recommendation algorithm variant for all users. The new variant loaded the full product catalog into memory (instead of sampling) on every request. Memory usage on the recommendation pods climbed from 2GB to 14GB over 20 minutes, triggering OOM kills. The search service degraded because it depended on recommendation for \"related items.\" Disabling the flag restored normal memory usage within 5 minutes.\n",
    "affected_services": [
      "feature-flags",
      "recommendations",
      "search"
    ]
  },
