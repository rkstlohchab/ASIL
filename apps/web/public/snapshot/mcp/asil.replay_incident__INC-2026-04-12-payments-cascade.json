  "incident": {
    "id": "INC-2026-04-12-payments-cascade",
    "env_key": "prod",
    "detected_at": "2026-04-12T14:24:00+00:00",
    "resolved_at": "2026-04-12T15:47:00+00:00",
    "title": "Payments p99 latency cascade after auth Redis pool refactor",
    "severity": "high",
    "summary": "Auth service deployment 8f2c1d4 changed the Redis connection pool semantics from per-request to long-lived. The shared session-token helper used by payments inherited the new behavior; under p99 traffic, half-open connections accumulated and the pool exhausted at 14:24. Payments p99 latency spiked from 120ms \u2192 4.2s. Cart's checkout flow failed because its timeout for payments was 3s. Rollback at 15:41 restored normal latency within 6 minutes.\n",
    "affected_services": [
      "auth",
      "payments",
      "cart"
    ]
  },
