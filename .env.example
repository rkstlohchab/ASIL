# ASIL environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ---- LLM routing ----
# Profiles: tight | balanced | generous (see packages/asil_core/llm.py)
ASIL_LLM_PROFILE=tight

# Daily $ ceiling. If exceeded, the ModelRouter auto-downgrades the active profile
# until the next UTC day. Leave empty to disable the guard.
ASIL_DAILY_BUDGET_USD=2.00

# ---- Provider API keys ----
# Only the keys for your active profile are required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
VOYAGE_API_KEY=

# Self-hosted embedding endpoint (BGE-large via TEI or vLLM). Used by `tight` profile.
ASIL_EMBED_ENDPOINT=http://localhost:8001/embed

# ---- GitHub (for repo ingestion) ----
GITHUB_TOKEN=

# ---- Datastore connections (defaults match docker-compose.yml) ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=asil_dev_password

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

POSTGRES_DSN=postgresql+asyncpg://asil:asil_dev_password@localhost:5432/asil
REDIS_URL=redis://localhost:6379/0

# ---- Observability ----
LOKI_URL=http://localhost:3100
PROMETHEUS_URL=http://localhost:9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=asil

# ---- App settings ----
ASIL_LOG_LEVEL=INFO
ASIL_ENV=dev
